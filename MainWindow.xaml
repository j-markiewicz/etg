<Window x:Class="etg.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:etg"
		mc:Ignorable="d"
		Title="MainWindow" Height="450" Width="800"
	>
	<Grid Grid.IsSharedSizeScope="True" Margin="4">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" SharedSizeGroup="A" />
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<TabControl Name="Tabs" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="4">
			<TabItem Name="PreviewTab">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<Image Source="/assets/plik.png" Width="16" Height="16" />
						<TextBlock Text="Otwórz Graf" Margin="4 2" />
					</StackPanel>
				</TabItem.Header>

				<Grid Grid.IsSharedSizeScope="True" Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" SharedSizeGroup="A" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" SharedSizeGroup="A" />
					</Grid.ColumnDefinitions>

					<Button Grid.Row="0" Grid.Column="0" Margin="4" Click="LoadFromFile_Click">Załaduj z pliku</Button>
					<TextBlock Name="Filename" Text="przykład.txt" Grid.Row="0" Grid.Column="1" Margin="4" />
					<Button Grid.Row="0" Grid.Column="2" Margin="4" Click="Open_Click">Otwórz</Button>
					<TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="4" Name="PreviewText" TextWrapping="NoWrap" AcceptsReturn="True" Text="..." />
				</Grid>
			</TabItem>

			<TabItem Name="GraphTab" IsEnabled="False">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<Image Source="/assets/graph.png" Width="16" Height="16" />
						<TextBlock Text="Graf" Margin="4 2" />
					</StackPanel>
				</TabItem.Header>
				
				<TextBlock Text="TODO: graf" />
			</TabItem>

			<TabItem Name="GanttTab" IsEnabled="False">
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<Image Source="/assets/gantt.png" Width="16" Height="16" />
						<TextBlock Text="Gantt" Margin="4 2" />
					</StackPanel>
				</TabItem.Header>

				<TextBlock Text="TODO: wykres gantta" />
			</TabItem>
		</TabControl>
	</Grid>
</Window>
