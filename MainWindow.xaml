<Window x:Class="etg.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:etg"
		mc:Ignorable="d"
		Title="MainWindow" Height="450" Width="800"
	>
    <Grid Grid.IsSharedSizeScope="True" Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" SharedSizeGroup="A" />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TabControl Name="Tabs" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="4">
            <TabItem Name="PreviewTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/assets/plik.png" Width="16" Height="16" />
                        <TextBlock Text="Otwórz Graf" Margin="4 2" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Lewa strona: plik -->
                    <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Margin="4" Click="LoadFromFile_Click">Załaduj z pliku</Button>
                        <TextBlock Name="Filename" Text="przykład.txt" Grid.Column="1" Margin="4" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Margin="4" Click="Open_Click">Otwórz</Button>
                    </Grid>

                    <!-- Dolna część: tekst + panel diagnostyczny -->
                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Margin="4" Name="PreviewText" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="..." />

                        <!-- Panel diagnostyczny -->
                        <Border Grid.Column="1" Margin="4" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Name="DiagnosticsPanel">
                                    <TextBlock Text="Diagnostyka" FontWeight="Bold" FontSize="14" Margin="0 0 0 8" />
                                    <TextBlock Name="DiagnosticsText" Text="Wczytaj plik i kliknij 'Otwórz', aby zobaczyć diagnostykę." TextWrapping="Wrap" Foreground="#666666" />
                                    <ItemsControl Name="DiagnosticsList" Margin="0 8 0 0" />
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Name="GraphTab" IsEnabled="False">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/assets/graph.png" Width="16" Height="16" />
                        <TextBlock Text="Graf" Margin="4 2" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0 0 0 4">

                        <TextBlock Text="Algorytm:"
                                   VerticalAlignment="Center"
                                   Margin="4"/>

                        <ComboBox Name="SchedulerComboBox"
                                Width="180"
                                Margin="4"
                                SelectedIndex="1">

                            <ComboBoxItem>ETG Scheduling</ComboBoxItem>
                            <ComboBoxItem>HEFT Scheduling</ComboBoxItem>

                        </ComboBox>

                        <Button Margin="4"
                                Click="Schedule_Click"
                                IsEnabled="False"
                                Name="ScheduleButton">

                            Szereguj

                        </Button>

                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas Name="GraphCanvas" Background="White" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Name="GanttTab" IsEnabled="False">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/assets/gantt.png" Width="16" Height="16" />
                        <TextBlock Text="Gantt" Margin="4 2" />
                    </StackPanel>
                </TabItem.Header>

                <Border Margin="8" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Canvas Name="GanttCanvas" Background="White" />
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
